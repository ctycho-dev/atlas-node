# Atlas Node Configuration
# Copy this to .env and fill in your values if you want to customize. 
# Otherwise, just run setup.sh and it will auto-generate everything for you.

# Your client UUID
UUID=

# Reality keys (generate with: docker run --rm ghcr.io/xtls/xray-core:latest x25519)
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
SHORT_ID=

# Reality destination (real website like www.microsoft.com)
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAMES=www.microsoft.com
