# Atlas Node Configuration
# Copy this to .env and fill in your values
# This single .env file configures both Xray and the Node Agent

# ============================================
# Xray Configuration (used by setup.sh)
# ============================================
# These are generated during initial setup and written to xray/config.json
# Keep them here for reference when registering the node in Atlas Control

# Reality keys (generate with: docker run --rm ghcr.io/xtls/xray-core:latest x25519)
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
SHORT_ID=

# Reality destination (real website to mimic)
REALITY_DEST=www.microsoft.com:443
REALITY_SERVER_NAMES=www.microsoft.com

# ============================================
# Node Agent API Configuration
# ============================================

# API secret for authenticating requests from Atlas Control
# Generate with: openssl rand -hex 32
API_SECRET=
